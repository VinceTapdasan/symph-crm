# ---- Build Stage ----
FROM node:20-alpine AS builder
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

# API_URL is baked into routes-manifest.json at build time (used by next.config.ts rewrites).
# Pass via: docker build --build-arg API_URL=https://... (see Cloud Build substitution _API_URL).
ARG API_URL=http://localhost:4000
ENV API_URL=${API_URL}

# NEXT_PUBLIC_API_URL is baked into the browser bundle at build time.
ARG NEXT_PUBLIC_API_URL=http://localhost:3001/api
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# PostHog analytics (public token — safe to bake in)
ENV NEXT_PUBLIC_POSTHOG_KEY=phc_CyVTX4zeuqphzYUwQsTWfyLMfWqMNb4gLu2HJJxFyF5R
ENV NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Copy workspace manifests for layer caching
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/database/package.json ./packages/database/
COPY apps/web/package.json ./apps/web/

# Install all dependencies
RUN pnpm install --frozen-lockfile

# Copy source
COPY packages ./packages
COPY apps/web ./apps/web

# Build Next.js with standalone output (set in next.config.ts)
WORKDIR /app/apps/web
RUN pnpm build

# ---- Production Stage ----
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# In a pnpm monorepo, Next.js standalone output nests files under apps/web/:
#   apps/web/server.js        ← entry point
#   apps/web/.next/           ← built assets
#   apps/web/public/          ← static assets
#   node_modules/             ← hoisted deps (at root of standalone dir)
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "apps/web/server.js"]
